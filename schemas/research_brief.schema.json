{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/autoresearch/research_brief.schema.json",
  "title": "ResearchBrief Artifact",
  "type": "object",
  "required": ["schema_version", "artifact_type", "artifact_id", "created_at", "updated_at", "producer", "status", "data"],
  "properties": {
    "schema_version": {"const": "autoresearch.v0"},
    "artifact_type": {"const": "research_brief"},
    "artifact_id": {"pattern": "^[a-z0-9][a-z0-9-]*$"},
    "created_at": {"type": "string"},
    "updated_at": {"type": "string"},
    "producer": {"type": "string"},
    "status": {"enum": ["draft", "candidate", "audited", "selected", "planned", "completed", "failed", "blocked", "needs_review", "checked"]},
    "data": {
      "type": "object",
      "required": ["topic", "goal", "keywords", "exclusions", "questions", "success_criteria", "status"],
      "properties": {
        "topic": {"type": "string", "minLength": 1},
        "goal": {"type": "string"},
        "keywords": {"type": "array", "items": {"type": "string"}},
        "exclusions": {"type": "array", "items": {"type": "string"}},
        "questions": {"type": "array", "items": {"type": "string"}},
        "success_criteria": {"type": "array", "items": {"type": "string"}},
        "status": {"type": "string"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
