{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PaperCandidate Artifact",
  "type": "object",
  "required": ["schema_version", "artifact_type", "artifact_id", "created_at", "updated_at", "producer", "status", "data"],
  "properties": {
    "schema_version": {"const": "autoresearch.v0"},
    "artifact_type": {"const": "paper_candidate"},
    "artifact_id": {"pattern": "^[a-z0-9][a-z0-9-]*$"},
    "created_at": {"type": "string"},
    "updated_at": {"type": "string"},
    "producer": {"type": "string"},
    "status": {"enum": ["draft", "candidate", "audited", "selected", "planned", "completed", "failed", "blocked", "needs_review", "checked"]},
    "data": {
      "type": "object",
      "required": ["paper_id", "title", "url", "authors", "year", "source", "code_url", "method_type", "relevance", "tags", "screening_reason", "status"],
      "properties": {
        "paper_id": {"pattern": "^[a-z0-9][a-z0-9-]*$"},
        "title": {"type": "string", "minLength": 1},
        "url": {"type": "string"},
        "authors": {"type": "array", "items": {"type": "string"}},
        "year": {"type": "string"},
        "source": {"type": "string"},
        "code_url": {"type": "string"},
        "method_type": {"type": "string"},
        "relevance": {"type": "integer", "minimum": 0, "maximum": 5},
        "tags": {"type": "array", "items": {"type": "string"}},
        "screening_reason": {"type": "string"},
        "status": {"type": "string"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
